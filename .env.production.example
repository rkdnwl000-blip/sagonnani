# ================================================
# 사고났니? 프로덕션 환경변수
# 이 파일을 복사하여 .env.production 으로 저장하고
# 실제 값으로 채워주세요.
# .env.production 은 절대 git에 커밋하지 마세요!
# ================================================

# ── 데이터베이스 ──────────────────────────────
POSTGRES_DB=sagonnani
POSTGRES_USER=sagonnani
POSTGRES_PASSWORD=강력한_패스워드_여기에

# NestJS에서 사용하는 연결 URL (docker-compose가 자동 설정)
# DATABASE_URL=postgresql://sagonnani:PASSWORD@postgres:5432/sagonnani

# ── JWT ──────────────────────────────────────
JWT_SECRET=최소_32자_이상의_랜덤_시크릿_키

# ── MinIO (S3 호환 스토리지) ──────────────────
MINIO_ROOT_USER=sagonnani_admin
MINIO_ROOT_PASSWORD=강력한_MinIO_패스워드

# API 서버에서 MinIO 접근 (docker 내부)
AWS_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=sagonnani_admin
AWS_SECRET_ACCESS_KEY=강력한_MinIO_패스워드
AWS_S3_BUCKET=sagonnani-photos
AWS_REGION=ap-northeast-2

# 클라이언트에서 파일 접근 (공개 URL)
MINIO_PUBLIC_URL=https://api.sagonnani.com:9000

# ── CORS ─────────────────────────────────────
# 허용할 Origin (쉼표 구분)
ALLOWED_ORIGINS=https://admin.sagonnani.com

# ── 관리자 웹 ─────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.sagonnani.com/api/v1

# ── 토스페이먼츠 결제 ─────────────────────────
# 토스페이먼츠 개발자 콘솔 > 내 상점 > API 키
TOSS_CLIENT_KEY=test_ck_로 시작하는_클라이언트_키
TOSS_SECRET_KEY=test_sk_로 시작하는_시크릿_키

# ── Firebase FCM (푸시 알림) ──────────────────
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > JSON 다운로드 후 Base64 인코딩
# cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ── 앱 설정 ──────────────────────────────────
PORT=3000
NODE_ENV=production

# 결제 리디렉션에서 사용하는 자기 자신의 URL
API_BASE_URL=https://api.sagonnani.com/api/v1
